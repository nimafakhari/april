FROM python:3.11-slim

WORKDIR /app

# Install test dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir pytest pytest-cov requests

COPY . .

# Run tests
CMD ["pytest", "tests/", "-v", "--cov=.", "--cov-report=html:/app/test-results"]
