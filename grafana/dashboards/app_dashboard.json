{
  "title": "Redis Counter App",
  "uid": "redis-counter-app",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(app_requests_total[1m])",
          "legendFormat": "{{ endpoint }} [{{ status }}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(app_request_duration_seconds_bucket[2m]))",
          "legendFormat": "p50 {{ endpoint }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(app_request_duration_seconds_bucket[2m]))",
          "legendFormat": "p95 {{ endpoint }}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(app_request_duration_seconds_bucket[2m]))",
          "legendFormat": "p99 {{ endpoint }}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Redis Counter Current Value",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "redis_counter_current_value",
          "legendFormat": "Counter",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Redis Errors",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "increase(redis_errors_total[5m])",
          "legendFormat": "Errors (5m)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(app_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "title": "Requests by Status",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum by (status) (app_requests_total)",
          "legendFormat": "HTTP {{ status }}",
          "refId": "A"
        }
      ]
    }
  ]
}
